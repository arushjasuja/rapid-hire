# Copy to .env and fill in. Only the API key is required to run.
# Every variable is optional except the key; the defaults below match config.py.

# --- required -------------------------------------------------------------
# A bare OPENAI_API_KEY also works; the prefixed one wins if both are set.
RAPIDHIRE_OPENAI_API_KEY=sk-your-key-here

# --- models (override to swap; gpt-4o is the scoring target) --------------
# RAPIDHIRE_REASONING_MODEL=gpt-4o
# RAPIDHIRE_INTAKE_MODEL=gpt-4o-mini
# RAPIDHIRE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- vector store ---------------------------------------------------------
# "persistent" writes to a local dir (single process). "http" talks to a
# ChromaDB server -- use this with docker-compose, which runs one.
# RAPIDHIRE_CHROMA_MODE=persistent
# RAPIDHIRE_CHROMA_PATH=./data/chroma
# RAPIDHIRE_CHROMA_HOST=localhost
# RAPIDHIRE_CHROMA_PORT=8000
# RAPIDHIRE_CRITERIA_DIR=./data/criteria
# RAPIDHIRE_TOP_K=5
# RAPIDHIRE_RELEVANCE_THRESHOLD=0.3

# --- scoring / routing ----------------------------------------------------
# RAPIDHIRE_BORDERLINE_LOW=50
# RAPIDHIRE_BORDERLINE_HIGH=70
# The AutoGen panel is off by default; the app is fully functional without it.
# RAPIDHIRE_ENABLE_PANEL=false
# RAPIDHIRE_PANEL_MAX_MESSAGES=8

# --- misc -----------------------------------------------------------------
# RAPIDHIRE_LOG_LEVEL=INFO
# RAPIDHIRE_REQUEST_TIMEOUT=60
# RAPIDHIRE_MAX_RETRIES=3
